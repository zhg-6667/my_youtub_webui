# Copy values into .env for application runtime.
# Keep env.txt for local editing if you do not want to open .env directly.
WORKFOLDER=./workfolder
MODEL_CACHE_DIR=./data/modelscope
CORS_ALLOW_ORIGINS=
CORS_ALLOW_ORIGIN_REGEX=
DEVICE=cuda
DEMUCS_DEVICE=
WHISPER_DEVICE=
FFMPEG_PATH=
FFPROBE_PATH=
LOCAL_UPLOAD_MAX_BYTES=4294967296
LOCAL_SUBTITLE_MAX_BYTES=20971520
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSLATE_CONCURRENCY=50
YTDLP_PROXY_PORT=
MAIL_ENABLED=false
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=587
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_TO_ADDRESSES=
MAIL_SMTP_SECURITY=tls
MAIL_NOTIFY_ON_SUCCESS=true
MAIL_NOTIFY_ON_FAILURE=true
FUNASR_MODEL=iic/SenseVoiceSmall
FUNASR_VAD_MODEL=fsmn-vad
VOXCPM_MODEL=OpenBMB/VoxCPM2
VOXCPM_MODEL_DIR=
HTTP_PROXY=
NO_PROXY=localhost,127.0.0.1,::1
